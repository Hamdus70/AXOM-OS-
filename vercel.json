{
  "version": 2,
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/chat/message.ts": {
    },
    "api/index.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/onboarding/chat",
      "destination": "/api/chat/message.ts"
    },
    {
      "source": "/api/chat",
      "destination": "/api/chat/message.ts"
    },
    {
      "source": "/api/chat/message",
      "destination": "/api/chat/message.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
